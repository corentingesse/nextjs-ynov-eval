{
  "format": "page",
  "id": "offer",
  "label": "Offer",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "available": {
        "type": "Boolean",
        "config": {
          "label": "Available",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": true
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "short_description": {
        "type": "Text",
        "config": {
          "label": "Short description",
          "placeholder": ""
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "repeat": true,
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "repeat": false,
                "customtypes": [
                  {
                    "id": "tag",
                    "fields": ["title"]
                  }
                ]
              }
            }
          }
        }
      },
      "emails": {
        "type": "Group",
        "config": {
          "label": "Emails administrateurs",
          "repeat": true,
          "fields": {
            "email": {
              "type": "Text",
              "config": {
                "label": "Email",
                "placeholder": ""
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "paragraph": {
              "type": "SharedSlice"
            },
            "title": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
